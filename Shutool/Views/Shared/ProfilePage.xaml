<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Shutool.Views.Shared.ProfilePage"
             BackgroundColor="{StaticResource PageBackground}"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <Grid RowDefinitions="Auto,*" Padding="24">

            <!-- Top Bar -->
            <Grid Grid.Row="0" Margin="0,48,0,16">
                <ImageButton
                    Source="settings.png"
                    HeightRequest="36"
                    WidthRequest="36"
                    BackgroundColor="Transparent"
                    HorizontalOptions="Start"
                    Clicked="OnBackClicked"/>
                <Label
                    Text="PROFILE"
                    Style="{StaticResource PixelLabel}"
                    FontSize="14"
                    TextColor="{StaticResource PrimaryGreen}"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"/>
                <ImageButton
                    Source="settings2.png"
                    HeightRequest="36"
                    WidthRequest="36"
                    BackgroundColor="Transparent"
                    HorizontalOptions="End"
                    Clicked="OnLogoutClicked"/>
            </Grid>

            <!-- Profile Card -->
            <Border
                Grid.Row="1"
                BackgroundColor="{StaticResource DarkCard}"
                StrokeShape="RoundRectangle 24"
                Stroke="Transparent"
                Padding="24"
                Margin="0,60,0,0">

                <VerticalStackLayout Spacing="12">

                    <!-- Avatar -->
                    <Border
                        BackgroundColor="White"
                        StrokeShape="Ellipse"
                        Stroke="Transparent"
                        HeightRequest="90"
                        WidthRequest="90"
                        HorizontalOptions="Center"
                        Margin="0,-70,0,8">
                        <Image
                            Source="profiles.png"
                            HeightRequest="80"
                            WidthRequest="80"
                            Aspect="AspectFit"/>
                    </Border>

                    <!-- Username -->
                    <Label Text="Username" Style="{StaticResource PixelLabel}" FontSize="9" TextColor="White"/>
                    <Border BackgroundColor="{StaticResource InputBackground}" StrokeShape="RoundRectangle 12" Stroke="Transparent" Padding="12,4">
                        <Entry x:Name="NameEntry" BackgroundColor="Transparent" TextColor="{StaticResource TextDark}"/>
                    </Border>

                    <!-- Email -->
                    <Label Text="Email" Style="{StaticResource PixelLabel}" FontSize="9" TextColor="White"/>
                    <Border BackgroundColor="{StaticResource InputBackground}" StrokeShape="RoundRectangle 12" Stroke="Transparent" Padding="12,4">
                        <Entry x:Name="EmailEntry" BackgroundColor="Transparent" TextColor="{StaticResource TextDark}" IsReadOnly="True"/>
                    </Border>

                    <!-- Change Password Section -->
                    <Label Text="New Password" Style="{StaticResource PixelLabel}" FontSize="9" TextColor="White" Margin="0,8,0,0"/>
                    <Border BackgroundColor="{StaticResource InputBackground}" StrokeShape="RoundRectangle 12" Stroke="Transparent" Padding="12,4">
                        <Entry x:Name="NewPasswordEntry" BackgroundColor="Transparent" TextColor="{StaticResource TextDark}" IsPassword="True" Placeholder="Leave blank to keep current" PlaceholderColor="#888"/>
                    </Border>

                    <Label Text="Confirm Password" Style="{StaticResource PixelLabel}" FontSize="9" TextColor="White"/>
                    <Border BackgroundColor="{StaticResource InputBackground}" StrokeShape="RoundRectangle 12" Stroke="Transparent" Padding="12,4">
                        <Entry x:Name="ConfirmPasswordEntry" BackgroundColor="Transparent" TextColor="{StaticResource TextDark}" IsPassword="True" Placeholder="Leave blank to keep current" PlaceholderColor="#888"/>
                    </Border>

                    <!-- Feedback -->
                    <Label
                        x:Name="FeedbackLabel"
                        FontSize="9"
                        IsVisible="False"
                        HorizontalOptions="Center"/>

                    <!-- Save Button -->
                    <Button
                        Text="Edit Profile"
                        Style="{StaticResource PixelButton}"
                        BackgroundColor="{StaticResource LightGreen}"
                        Clicked="OnSaveClicked"
                        Margin="0,8,0,0"/>

                </VerticalStackLayout>
            </Border>

        </Grid>
    </ScrollView>
</ContentPage>