<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Shutool.Views.Driver.DriverMainPage"
             BackgroundColor="{StaticResource PageBackground}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- Top Bar -->
        <Grid Grid.Row="0" Padding="20,52,20,8">
            <ImageButton
                Source="settings.png"
                HeightRequest="36"
                WidthRequest="36"
                BackgroundColor="Transparent"
                HorizontalOptions="Start"
                Clicked="OnSettingsClicked"/>
            <ImageButton
                Source="settings2.png"
                HeightRequest="36"
                WidthRequest="36"
                BackgroundColor="Transparent"
                HorizontalOptions="End"
                Clicked="OnLogoutClicked"/>
        </Grid>

        <!-- Driver Info -->
        <VerticalStackLayout Grid.Row="1" HorizontalOptions="Center" Spacing="8" Margin="0,0,0,8">
            <Border
                BackgroundColor="White"
                StrokeShape="Ellipse"
                Stroke="{StaticResource YellowAccent}"
                StrokeThickness="3"
                HeightRequest="90"
                WidthRequest="90"
                HorizontalOptions="Center">
                <Image
                    Source="profiles.png"
                    HeightRequest="80"
                    WidthRequest="80"
                    Aspect="AspectFit"/>
            </Border>

            <Border
                BackgroundColor="{StaticResource YellowAccent}"
                StrokeShape="RoundRectangle 20"
                Stroke="Transparent"
                Padding="20,6"
                HorizontalOptions="Center">
                <Label
                    x:Name="DriverNameLabel"
                    Text="Driver"
                    FontSize="13"
                    TextColor="{StaticResource TextDark}"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"/>
            </Border>

            <Label
                x:Name="ShuttleNumberLabel"
                Text="Shuttle #--"
                FontSize="13"
                TextColor="{StaticResource TextDark}"
                FontAttributes="Bold"
                HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- Dark Panel -->
        <Grid Grid.Row="2"
              BackgroundColor="{StaticResource DarkCard}"
              RowDefinitions="Auto,Auto,*">

            <!-- Tab Buttons -->
            <Grid Grid.Row="0"
                  ColumnDefinitions="*,*"
                  Padding="20,16,20,8"
                  ColumnSpacing="8">
                <Button
                    x:Name="PendingTabBtn"
                    Grid.Column="0"
                    Text="Pending Request"
                    BackgroundColor="{StaticResource YellowAccent}"
                    TextColor="{StaticResource TextDark}"
                    CornerRadius="20"
                    FontSize="10"
                    HeightRequest="40"
                    Clicked="OnPendingTabClicked"/>
                <Button
                    x:Name="HistoryTabBtn"
                    Grid.Column="1"
                    Text="Request History"
                    BackgroundColor="{StaticResource LightGreen}"
                    TextColor="{StaticResource TextDark}"
                    CornerRadius="20"
                    FontSize="10"
                    HeightRequest="40"
                    Clicked="OnHistoryTabClicked"/>
            </Grid>

            <!-- Panel Title -->
            <Label
                x:Name="PanelTitleLabel"
                Grid.Row="1"
                Text="Pending Request"
                Style="{StaticResource PixelLabel}"
                FontSize="12"
                TextColor="{StaticResource YellowAccent}"
                HorizontalOptions="Center"
                Margin="0,4,0,8"/>

            <!-- Table -->
            <Border
                Grid.Row="2"
                BackgroundColor="White"
                StrokeShape="RoundRectangle 16"
                Stroke="Transparent"
                Margin="16,0,16,16"
                Padding="0">

                <Grid RowDefinitions="Auto,*">

                    <!-- Table Header -->
                    <Grid
                        Grid.Row="0"
                        ColumnDefinitions="*,*,*"
                        Padding="12,10"
                        BackgroundColor="Transparent">
                        <Label Grid.Column="0" Text="Date" FontAttributes="Bold" FontSize="11" TextColor="{StaticResource TextDark}"/>
                        <Label Grid.Column="1" Text="Name" FontAttributes="Bold" FontSize="11" TextColor="{StaticResource TextDark}" HorizontalOptions="Center"/>
                        <Label Grid.Column="2" Text="Status" FontAttributes="Bold" FontSize="11" TextColor="{StaticResource TextDark}" HorizontalOptions="End"/>
                    </Grid>

                    <BoxView Grid.Row="0" VerticalOptions="End" HeightRequest="1" Color="{StaticResource YellowAccent}"/>

                    <!-- Pending List -->
                    <CollectionView
                        x:Name="PendingCollection"
                        Grid.Row="1"
                        SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <VerticalStackLayout>
                                    <Grid ColumnDefinitions="*,*,*" Padding="12,10">
                                        <Label
                                            Grid.Column="0"
                                            Text="{Binding CreatedAt, StringFormat='{0:MM/dd}'}"
                                            FontSize="11"
                                            TextColor="{StaticResource TextDark}"/>
                                        <Label
                                            Grid.Column="1"
                                            Text="{Binding RiderName}"
                                            FontSize="11"
                                            TextColor="{StaticResource TextDark}"
                                            HorizontalOptions="Center"
                                            LineBreakMode="TailTruncation"/>
                                        <Label
                                            Grid.Column="2"
                                            Text="Pending"
                                            FontSize="11"
                                            TextColor="{StaticResource YellowAccent}"
                                            HorizontalOptions="End"/>
                                    </Grid>
                                    <BoxView HeightRequest="1" Color="{StaticResource YellowAccent}" Opacity="0.3" Margin="12,0"/>
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- History List -->
                    <CollectionView
                        x:Name="HistoryCollection"
                        Grid.Row="1"
                        IsVisible="False"
                        SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <VerticalStackLayout>
                                    <Grid ColumnDefinitions="*,*,*" Padding="12,10">
                                        <Label
                                            Grid.Column="0"
                                            Text="{Binding CreatedAt, StringFormat='{0:MM/dd}'}"
                                            FontSize="11"
                                            TextColor="{StaticResource TextDark}"/>
                                        <Label
                                            Grid.Column="1"
                                            Text="{Binding RiderName}"
                                            FontSize="11"
                                            TextColor="{StaticResource TextDark}"
                                            HorizontalOptions="Center"
                                            LineBreakMode="TailTruncation"/>
                                        <Label
                                            Grid.Column="2"
                                            Text="Handled"
                                            FontSize="11"
                                            TextColor="{StaticResource LightGreen}"
                                            HorizontalOptions="End"/>
                                    </Grid>
                                    <BoxView HeightRequest="1" Color="{StaticResource YellowAccent}" Opacity="0.3" Margin="12,0"/>
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Empty State -->
                    <Label
                        x:Name="EmptyLabel"
                        Grid.Row="1"
                        Text="No requests."
                        FontSize="11"
                        TextColor="#888"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Margin="0,24"
                        IsVisible="False"/>

                </Grid>
            </Border>
        </Grid>

        <!-- Bottom Buttons -->
        <Grid
            Grid.Row="3"
            ColumnDefinitions="*,*"
            ColumnSpacing="12"
            Padding="20,12"
            BackgroundColor="{StaticResource DarkCard}">

            <Button
                x:Name="MarkAllBtn"
                Grid.Column="0"
                Text="Mark All Complete"
                BackgroundColor="{StaticResource LightGreen}"
                TextColor="White"
                CornerRadius="20"
                FontSize="10"
                HeightRequest="45"
                Clicked="OnMarkAllCompleteClicked"/>

            <Button
                Grid.Column="1"
                Text="Refresh"
                BackgroundColor="{StaticResource BlueAccent}"
                TextColor="White"
                CornerRadius="20"
                FontSize="10"
                HeightRequest="45"
                Clicked="OnRefreshClicked"/>

        </Grid>

    </Grid>
</ContentPage>